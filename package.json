{
	"name": "vrc-hub",
	"version": "0.0.1",
	"license": "BSD-3-Clause",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write . && eslint . --fix",
		"struct": "openapi-typescript https://vrchatapi.github.io/specification/openapi.yaml --output src/lib/api/vrchat.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.1",
		"@sveltejs/kit": "^2.5.4",
		"@sveltejs/vite-plugin-svelte": "^3.0.2",
		"@tailwindcss/typography": "^0.5.10",
		"@tauri-apps/api": "^1.5.3",
		"@tauri-apps/cli": "^1.5.11",
		"@types/eslint": "^8.56.5",
		"@typescript-eslint/eslint-plugin": "^7.2.0",
		"@typescript-eslint/parser": "^7.2.0",
		"autoprefixer": "^10.4.18",
		"daisyui": "^4.7.3",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-import": "^2.29.1",
		"eslint-plugin-svelte": "2.36.0-next.10",
		"eslint-plugin-vitest": "^0.3.26",
		"lucide-svelte": "^0.356.0",
		"openapi-fetch-tauri": "^0.0.2",
		"openapi-typescript": "^6.7.5",
		"postcss": "^8.4.35",
		"postcss-load-config": "^5.0.3",
		"prettier": "^3.2.5",
		"prettier-plugin-svelte": "^3.2.2",
		"prettier-plugin-tailwindcss": "^0.5.12",
		"svelte": "5.0.0-next.80",
		"svelte-check": "^3.6.7",
		"sveltekit-i18n": "^2.4.2",
		"tailwindcss": "^3.4.1",
		"tslib": "^2.6.2",
		"typescript": "^5.4.2",
		"vite": "^5.1.6",
		"vitest": "^1.4.0"
	},
	"type": "module"
}
